RPD <- do.call(rbind, lapply(PDlist, '[[', 'R')) %>% arrange(R2); names(RPD) <- c('R2','PD','Lower','Upper') # Rugosity and Height Range
DPD <- do.call(rbind, lapply(PDlist, '[[', 'D')) %>% arrange(D); names(DPD) <- c('D','PD','Lower','Upper') # Fractal Dimension and Height Range
HPD <- do.call(rbind, lapply(PDlist, '[[', 'H')) %>% arrange(H2); names(HPD) <- c('H2','PD','Lower','Upper') # Fractal Dimension and Rugosity
#Extract probability of zero coefficients
(coefR <- CI95(unlist(lapply(PDlist,'[[', 'R_hu'))))
(coefH <- CI95(unlist(lapply(PDlist,'[[', 'H_hu'))))
(coefD <- CI95(unlist(lapply(PDlist,'[[', 'D_hu'))))
# Compute mean and variance bounds in each modeled relationship (transform to probability of >0 )
Rvec <- seq(-13.7,0.8, 0.01); Dvec <- seq(2,3, 0.01); Hvec <- seq(-7,1.2, 0.01)
R_hu <- data.frame(R = Rvec, Mean = 1-(exp(coefR[1]*Rvec)), Lower = 1-(exp(coefR[2]*Rvec)), Upper = 1-(exp(coefR[3]*Rvec)))
D_hu <- data.frame(D = Dvec, Mean = 1-(exp(coefD[1]*Dvec)), Lower = 1-(exp(coefD[2]*Dvec)), Upper = 1-(exp(coefD[3]*Dvec)))
H_hu <- data.frame(H = Hvec, Mean = 1-(exp(coefH[1]*Hvec)), Lower = 1-(exp(coefH[2]*Hvec)), Upper = 1-(exp(coefH[3]*Hvec)))
R_hu
