?gp
# Compare linear and non-linear formats for each pairwise complexity variable combination (using a quick brms run-through)
# Rugosity versus Height Range
RH_brm_mod <- add_criterion(brm(R2 ~ H2 + gp(Lat, Lon), family = 'gaussian', # GPS details included as fixed effects variables
data = TmpData, chains = 1, iter = 1000, warmup = 500, backend = 'cmdstanr'), 'loo')
install.packages("qbrms")
library(qbrms)
install.packages('INLA', repos=c(getOption('repos'), INLA='https://inla.r-inla-download.org/R/stable'), dep=TRUE)
library(qbrms)
?qbrm
# Compare linear and non-linear formats for each pairwise complexity variable combination (using a quick brms run-through)
# Rugosity versus Height Range
RH_brm_mod <- add_criterion(qbrm(R2 ~ H2 + gp(Lat, Lon), family = 'gaussian', # GPS details included as fixed effects variables using a Gaussian process smoother
data = TmpData, chains = 1, iter = 1000, warmup = 500), 'loo')
# Compare linear and non-linear formats for each pairwise complexity variable combination (using a quick brms run-through)
# Rugosity versus Height Range
RH_brm_mod <- qbrm(R2 ~ H2 + gp(Lat, Lon), family = 'gaussian', # GPS details included as fixed effects variables using a Gaussian process smoother
data = TmpData, chains = 1, iter = 1000, warmup = 500)
View(RH_brm_mod)
RH_brm_mod2 <- qbrm(R2 ~ H2 + I(H2^2) + gp(Lat, Lon), family = 'gaussian',
data = TmpData, chains = 1, iter = 1000, warmup = 500)
# Access model fit
compare_models(RH_brm_mod, RH_brm_mod2, criterion = 'loo')
loo(RH_brm_mod)
# Compare linear and non-linear formats for each pairwise complexity variable combination (using a quick brms run-through)
# Rugosity versus Height Range
RH_brm_mod <- qbrms(R2 ~ H2 + gp(Lat, Lon), family = 'gaussian', # GPS details included as fixed effects variables using a Gaussian process smoother
data = TmpData, chains = 1, iter = 1000, warmup = 500, control.compute = list(elpd_loo = TRUE))
RH_brm_mod2 <- qbrms(R2 ~ H2 + I(H2^2) + gp(Lat, Lon), family = 'gaussian',
data = TmpData, chains = 1, iter = 1000, warmup = 500, control.compute = list(elpd_loo = TRUE))
# Access model fit
compare_models(RH_brm_mod, RH_brm_mod2, criterion = 'loo')
# Compare linear and non-linear formats for each pairwise complexity variable combination (using a quick brms run-through)
# Rugosity versus Height Range
RH_brm_mod <- qbrm(R2 ~ H2 + gp(Lat, Lon), family = 'gaussian', # GPS details included as fixed effects variables using a Gaussian process smoother
data = TmpData, chains = 1, iter = 1000, warmup = 500)
RH_brm_mod2 <- qbrm(R2 ~ H2 + I(H2^2) + gp(Lat, Lon), family = 'gaussian',
data = TmpData, chains = 1, iter = 1000, warmup = 500)
# Access model fit
compare_models(RH_brm_mod, RH_brm_mod2, criterion = 'waic')
# Next determine the most appropriate model structure for each of the pairwise comparisons.
# Extract random data sample
TmpData <- RawData %>% dplyr::select(Lon, Lat, D, R2, H2) %>% collect() %>% sample_n(size = N*100, replace = FALSE)
# Compare linear and non-linear formats for each pairwise complexity variable combination (using a quick brms run-through)
# Rugosity versus Height Range
RH_brm_mod <- qbrm(R2 ~ H2 + gp(Lat, Lon), family = 'gaussian', # GPS details included as fixed effects variables using a Gaussian process smoother
data = TmpData, chains = 1, iter = 1000, warmup = 500)
RH_brm_mod2 <- qbrm(R2 ~ H2 + I(H2^2) + gp(Lat, Lon), family = 'gaussian',
data = TmpData, chains = 1, iter = 1000, warmup = 500)
# Access model fit
compare_models(RH_brm_mod, RH_brm_mod2, criterion = 'waic')
# Compare linear and non-linear formats for each pairwise complexity variable combination (using a quick brms run-through)
# Rugosity versus Height Range
RH_brm_mod <- qbrm(R2 ~ H2 + gp(Lat, Lon), family = 'gaussian', # GPS details included as fixed effects variables using a Gaussian process smoother
data = TmpData, chains = 1, iter = 4000, warmup = 2000)
